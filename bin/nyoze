#!/usr/bin/env php
<?php

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',       // When running from framework dir
    __DIR__ . '/../../../autoload.php',         // When installed as dependency
    getcwd() . '/vendor/autoload.php',          // When running from project root
];

$autoloaded = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Could not find autoloader. Run 'composer install' first.\n");
    exit(1);
}

use Nyoze\Core\App;
use Nyoze\CLI\Console;

$app = new App();

// Load app bootstrap if exists
$bootstrapPath = getcwd() . '/bootstrap.php';
if (file_exists($bootstrapPath)) {
    $bootstrap = require $bootstrapPath;
    if (is_callable($bootstrap)) {
        $bootstrap($app);
    }
}

$console = new Console($app);
exit($console->run($argv));
